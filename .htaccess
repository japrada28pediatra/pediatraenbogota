Options -MultiViews

RewriteEngine On

# Forzar HTTPS y dominio sin www
RewriteCond %{HTTPS} !=on [OR]
RewriteCond %{HTTP_HOST} ^www\.pediatraenbogota\.com$ [NC]
RewriteRule ^ https://pediatraenbogota.com%{REQUEST_URI} [R=301,L]

# /index.html -> /
RewriteCond %{THE_REQUEST} \s/+index\.html(?:[\s?]) [NC]
RewriteRule ^index\.html$ / [R=301,L]

# /archivo.html -> /archivo/
# Solo aplica a archivos HTML ubicados directamente en el root
RewriteCond %{THE_REQUEST} \s/+([^/?]+)\.html(?:[\s?]) [NC]
RewriteRule ^([^/]+)\.html$ /$1/ [R=301,L,NE]

# /archivo -> /archivo/
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{DOCUMENT_ROOT}/$1.html -f
RewriteRule ^([^/]+)$ /$1/ [R=301,L,NE]

# /archivo/ carga internamente /archivo.html
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{DOCUMENT_ROOT}/$1.html -f
RewriteRule ^([^/]+)/?$ $1.html [L]
